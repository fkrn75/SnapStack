<Window x:Class="SnapStack.Views.CaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="#33000000" Topmost="True" ShowInTaskbar="False"
        ResizeMode="NoResize" Cursor="Cross">
    <!-- 가상화면 전체를 덮는 반투명 오버레이. 드래그로 영역 선택(CAP-07). -->
    <Canvas x:Name="RootCanvas">
        <Rectangle x:Name="SelectionRect"
                   Stroke="#FF3399FF" StrokeThickness="1.5"
                   Fill="#220099FF" Visibility="Collapsed"/>
        <Border x:Name="SizeLabel" Background="#CC000000" CornerRadius="3"
                Padding="6,2" Visibility="Collapsed">
            <TextBlock x:Name="SizeText" Foreground="White" FontSize="12"/>
        </Border>
    </Canvas>
</Window>

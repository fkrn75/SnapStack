<Window x:Class="SnapStack.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SnapStack.ViewModels"
        xmlns:ctl="clr-namespace:SnapStack.Views.Controls"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
        Title="SnapStack 설정" Height="520" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">
    <DockPanel Margin="0">
        <!-- 하단 버튼 바 -->
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="저장" Command="{Binding SaveCommand}"
                        IsDefault="True" MinWidth="80" Padding="10,4" Margin="0,0,8,0"/>
                <Button Content="취소" IsCancel="True" MinWidth="80" Padding="10,4"/>
            </StackPanel>
        </Border>

        <TabControl Margin="8">
            <!-- 일반: 시작 시 자동 실행 · 히스토리 영속 -->
            <TabItem Header="일반">
                <StackPanel Margin="12">
                    <CheckBox Content="Windows 시작 시 자동 실행 (트레이 상주)"
                              IsChecked="{Binding RunAtStartup}" Margin="0,6"/>
                    <CheckBox Content="히스토리 세션 영속화 (재시작 시 복원)"
                              IsChecked="{Binding PersistHistory}" Margin="0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <TextBlock Text="히스토리 보존 개수:" VerticalAlignment="Center" Width="140"/>
                        <TextBox Text="{Binding HistoryLimit}" Width="80"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- 저장: 기본 폴더 · 포맷 -->
            <TabItem Header="저장">
                <StackPanel Margin="12">
                    <TextBlock Text="기본 저장 폴더" Margin="0,6,0,2"/>
                    <TextBox Text="{Binding SaveFolder}" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <TextBlock Text="기본 저장 포맷:" VerticalAlignment="Center" Width="140"/>
                        <ComboBox ItemsSource="{Binding FormatOptions}"
                                  SelectedItem="{Binding DefaultFormat}" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- 캡쳐: 지연 초 · 캡쳐 후 편집기 -->
            <TabItem Header="캡쳐">
                <StackPanel Margin="12">
                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <TextBlock Text="지연 캡쳐 시간(초):" VerticalAlignment="Center" Width="140"/>
                        <TextBox Text="{Binding DelaySeconds}" Width="80"/>
                    </StackPanel>
                    <CheckBox Content="캡쳐 후 편집기 자동 열기"
                              IsChecked="{Binding OpenEditorAfterCapture}" Margin="0,6"/>
                </StackPanel>
            </TabItem>

            <!-- 단축키: 재지정 가능(HotkeyCaptureBox). 칸 클릭→키 조합 입력 -->
            <TabItem Header="단축키">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" Foreground="#666"
                               Text="단축키 칸을 클릭한 뒤 원하는 키 조합을 누르세요. Esc/Backspace/Delete=비우기. 저장 시 적용됩니다."
                               Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <ItemsControl ItemsSource="{Binding Hotkeys}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               VerticalAlignment="Center"/>
                                    <ctl:HotkeyCaptureBox Grid.Column="1"
                                               Hotkey="{Binding Gesture, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               MinWidth="200" Padding="6,4"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </TabItem>

            <!-- 트레이: 닫기/최소화 동작(상주) -->
            <TabItem Header="트레이">
                <StackPanel Margin="12">
                    <CheckBox Content="창을 닫으면 종료하지 않고 트레이로 최소화"
                              IsChecked="{Binding MinimizeToTrayOnClose}" Margin="0,6"/>
                    <CheckBox Content="창을 최소화하면 트레이로 숨김"
                              IsChecked="{Binding MinimizeToTrayOnMinimize}" Margin="0,6"/>
                    <TextBlock Foreground="#666" TextWrapping="Wrap" Margin="0,8,0,0"
                               Text="트레이 아이콘을 두 번 클릭하거나 우클릭 → '열기'로 창을 다시 표시합니다. 완전히 종료하려면 트레이 우클릭 → '종료'를 사용하세요."/>
                </StackPanel>
            </TabItem>

            <!-- 정보 -->
            <TabItem Header="정보">
                <StackPanel Margin="12">
                    <TextBlock Text="SnapStack" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Windows 화면 캡쳐 · 주석 · 클립보드 도구" Margin="0,4"/>
                    <TextBlock Text="v1.0 (MVP) · .NET 8 / WPF" Foreground="#666" Margin="0,4"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

<Window x:Class="SnapStack.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SnapStack.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:EditorViewModel}"
        Title="SnapStack 편집기" Height="760" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- 좌측 도구바 버튼 공통 스타일(아이콘/문자) -->
        <Style x:Key="ToolButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3C3C40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BarButton" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MinWidth" Value="56"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- 좌측 도구바 (EDT-11) — ToggleButton은 Tool 속성에 바인딩되어 활성 표시 -->
        <Border DockPanel.Dock="Left" Background="#2D2D30" Width="56">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,6">
                    <ToggleButton Style="{StaticResource ToolButton}" Content="↖" ToolTip="선택/이동 (V)"
                                  IsChecked="{Binding IsSelectTool, Mode=OneWay}" Command="{Binding SelectToolCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="✎" ToolTip="펜 (P)"
                                  IsChecked="{Binding IsPenTool, Mode=OneWay}" Command="{Binding PenCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="🖍" ToolTip="형광펜 (H)"
                                  IsChecked="{Binding IsHighlighterTool, Mode=OneWay}" Command="{Binding HighlighterCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="▭" ToolTip="사각형 (R)"
                                  IsChecked="{Binding IsRectangleTool, Mode=OneWay}" Command="{Binding RectangleToolCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="◯" ToolTip="타원 (O)"
                                  IsChecked="{Binding IsEllipseTool, Mode=OneWay}" Command="{Binding EllipseToolCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="╱" ToolTip="직선 (L)"
                                  IsChecked="{Binding IsLineTool, Mode=OneWay}" Command="{Binding LineToolCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="➔" ToolTip="화살표 (A)"
                                  IsChecked="{Binding IsArrowTool, Mode=OneWay}" Command="{Binding ArrowToolCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="T" ToolTip="텍스트 (T)"
                                  IsChecked="{Binding IsTextTool, Mode=OneWay}" Command="{Binding TextToolCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="①" ToolTip="번호 (N)"
                                  IsChecked="{Binding IsNumberTool, Mode=OneWay}" Command="{Binding NumberToolCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="▦" ToolTip="모자이크 (M)"
                                  IsChecked="{Binding IsMosaicTool, Mode=OneWay}" Command="{Binding MosaicToolCommand}"/>
                    <ToggleButton Style="{StaticResource ToolButton}" Content="⛶" ToolTip="자르기 (C)"
                                  IsChecked="{Binding IsCropTool, Mode=OneWay}" Command="{Binding CropToolCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 상단 옵션바 (EDT-09) + 출력 툴바(적용/복사/저장/취소) -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <!-- 색상 -->
                <TextBlock Text="색상" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ItemsControl x:Name="ColorSwatches" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <Border x:Name="CurrentColorBox" Width="22" Height="22" Margin="6,0,12,0"
                        BorderBrush="#888" BorderThickness="1" CornerRadius="2"/>

                <!-- 굵기 -->
                <TextBlock Text="굵기" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Slider x:Name="ThicknessSlider" Width="120" Minimum="1" Maximum="40"
                        Value="{Binding Thickness, Mode=TwoWay}" VerticalAlignment="Center"
                        TickFrequency="1" IsSnapToTickEnabled="True"/>
                <TextBlock Text="{Binding Thickness, StringFormat='{}{0:0}px'}" Foreground="#CCC"
                           Width="38" VerticalAlignment="Center" Margin="6,0,12,0"/>

                <!-- 채움(도형용) -->
                <CheckBox x:Name="FillCheck" Content="채움" Foreground="#CCC" VerticalAlignment="Center"
                          IsChecked="{Binding FillEnabled, Mode=TwoWay}" Margin="0,0,12,0"/>

                <Separator Margin="6,0" Background="#555" Width="1"/>

                <!-- Undo/Redo -->
                <Button Style="{StaticResource BarButton}" Content="↶ 취소" Command="{Binding UndoEditCommand}"/>
                <Button Style="{StaticResource BarButton}" Content="↷ 재실행" Command="{Binding RedoEditCommand}"/>

                <Separator Margin="6,0" Background="#555" Width="1"/>

                <!-- 출력/확정 -->
                <Button Style="{StaticResource BarButton}" Content="적용" Command="{Binding ApplyCommand}"
                        Background="#0E7A0E" Foreground="White" FontWeight="Bold"/>
                <Button Style="{StaticResource BarButton}" Content="복사" Command="{Binding CopyCommand}"/>
                <Button Style="{StaticResource BarButton}" Content="저장" Command="{Binding SaveCommand}"/>
                <Button Style="{StaticResource BarButton}" Content="취소" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Border>

        <!-- 하단 상태바 (좌표/크기 — EDT-11) -->
        <Border DockPanel.Dock="Bottom" Background="#007ACC" Padding="10,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" x:Name="CoordText" Foreground="White" Margin="12,0,0,0"/>
                <TextBlock Text="{Binding Status}" Foreground="White"/>
            </DockPanel>
        </Border>

        <!-- 중앙 캔버스: 베이스 이미지 + InkCanvas(펜/형광펜) + 오버레이 Canvas(도형/텍스트/번호/모자이크/자르기) -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="#1A1A1A">
            <!-- CanvasHost: 원본 픽셀 크기로 고정(코드비하인드에서 Width/Height 설정). 모든 레이어가 정확히 겹친다. -->
            <Grid x:Name="CanvasHost" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                <!-- ① 베이스 이미지(원본 1:1) -->
                <Image x:Name="BaseImageView" Stretch="Fill"/>
                <!-- ② 모자이크/래스터 주석 Canvas(이미지 위, Ink 아래) -->
                <Canvas x:Name="RasterCanvas" IsHitTestVisible="False"/>
                <!-- ③ InkCanvas(펜/형광펜) — 활성 시에만 입력 받음 -->
                <InkCanvas x:Name="Ink" Background="Transparent"/>
                <!-- ④ 도형/텍스트/번호/크롭 오버레이 Canvas(최상단, 마우스 직접 처리) -->
                <Canvas x:Name="OverlayCanvas" Background="Transparent"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
